{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "functionPlanName": {
      "type": "string",
      "defaultValue": "[concat(parameters('functionAppName'), '-plan')]"
    },
    "functionAppName": {
      "type": "string"
    },
    "storageMode": {
      "type": "string",
      "defaultValue": "new",
      "allowedValues": [
        "new",
        "existing"
      ]
    },
    "storageAccountName": {
      "type": "string"
    },
    "storageSubscriptionId": {
      "type": "string",
      "defaultValue": ""
    },
    "storageResourceGroup": {
      "type": "string",
      "defaultValue": ""
    },
    "storageAccountResourceId": {
      "type": "string",
      "defaultValue": ""
    },
    "deploymentContainerName": {
      "type": "string",
      "defaultValue": ""
    },
    "logAnalyticsMode": {
      "type": "string",
      "defaultValue": "new",
      "allowedValues": [
        "new",
        "existing"
      ]
    },
    "logAnalyticsName": {
      "type": "string",
      "defaultValue": "[concat(parameters('functionAppName'), '-logs')]"
    },
    "logAnalyticsSubscriptionId": {
      "type": "string",
      "defaultValue": ""
    },
    "logAnalyticsResourceGroup": {
      "type": "string",
      "defaultValue": ""
    },
    "logAnalyticsResourceId": {
      "type": "string",
      "defaultValue": ""
    },
    "appInsightsMode": {
      "type": "string",
      "defaultValue": "new",
      "allowedValues": [
        "new",
        "existing"
      ]
    },
    "applicationInsightsName": {
      "type": "string",
      "defaultValue": "[concat(parameters('functionAppName'), '-ai')]"
    },
    "applicationInsightsSubscriptionId": {
      "type": "string",
      "defaultValue": ""
    },
    "applicationInsightsResourceGroup": {
      "type": "string",
      "defaultValue": ""
    },
    "applicationInsightsResourceId": {
      "type": "string",
      "defaultValue": ""
    },
    "applicationInsightsConnectionString": {
      "type": "string",
      "defaultValue": ""
    },
    "azureKeyVaultUrl": {
      "type": "string"
    },
    "dnsSubscriptionId": {
      "type": "string",
      "defaultValue": ""
    },
    "dnsResourceGroup": {
      "type": "string"
    },
    "dnsZoneName": {
      "type": "string"
    },
    "dnsChallengeZoneName": {
      "type": "string",
      "defaultValue": ""
    },
    "dnsChallengeResourceGroup": {
      "type": "string",
      "defaultValue": ""
    },
    "maximumInstanceCount": {
      "type": "int",
      "defaultValue": 40
    },
    "instanceMemoryMB": {
      "type": "int",
      "defaultValue": 2048,
      "allowedValues": [
        512,
        2048,
        4096
      ]
    },
    "zoneRedundant": {
      "type": "bool",
      "defaultValue": false
    },
    "dnsZoneResourceId": {
      "type": "string",
      "defaultValue": ""
    },
    "dnsRoleAssignmentEnabled": {
      "type": "bool",
      "defaultValue": true
    },
    "keyVaultSubscriptionId": {
      "type": "string",
      "defaultValue": ""
    },
    "keyVaultResourceGroup": {
      "type": "string",
      "defaultValue": ""
    },
    "keyVaultResourceId": {
      "type": "string",
      "defaultValue": ""
    },
    "keyVaultRoleAssignmentEnabled": {
      "type": "bool",
      "defaultValue": true
    }
  },
  "variables": {
    "resourceToken": "[toLower(uniqueString(subscription().id, resourceGroup().name, parameters('location'), parameters('functionAppName')))]",
    "effectiveDeploymentContainerName": "[if(empty(parameters('deploymentContainerName')), concat('app-package-', take(parameters('functionAppName'), 16), '-', take(variables('resourceToken'), 7)), parameters('deploymentContainerName'))]",
    "storageBlobDataOwnerRoleDefinitionId": "b7e6dc6d-f1e8-4753-8033-0f276bb0955b",
    "dnsZoneContributorRoleDefinitionId": "befefa01-2a29-4197-83a8-272ff33ce314",
    "keyVaultCertificatesOfficerRoleDefinitionId": "a4417e6f-fecd-4de8-b567-7b0420556985",
    "effectiveStorageSubscriptionId": "[if(empty(parameters('storageSubscriptionId')), subscription().subscriptionId, parameters('storageSubscriptionId'))]",
    "effectiveStorageResourceGroup": "[if(empty(parameters('storageResourceGroup')), resourceGroup().name, parameters('storageResourceGroup'))]",
    "effectiveStorageAccountResourceId": "[if(empty(parameters('storageAccountResourceId')), resourceId(variables('effectiveStorageSubscriptionId'), variables('effectiveStorageResourceGroup'), 'Microsoft.Storage/storageAccounts', parameters('storageAccountName')), parameters('storageAccountResourceId'))]",
    "storageContainerManagedByTemplate": "[or(equals(parameters('storageMode'), 'new'), and(not(empty(parameters('storageAccountResourceId'))), startsWith(toLower(parameters('storageAccountResourceId')), toLower(concat(resourceGroup().id, '/providers/Microsoft.Storage/storageAccounts/')))), and(empty(parameters('storageAccountResourceId')), equals(variables('effectiveStorageSubscriptionId'), subscription().subscriptionId), equals(toLower(variables('effectiveStorageResourceGroup')), toLower(resourceGroup().name))))]",
    "effectiveLogAnalyticsSubscriptionId": "[if(empty(parameters('logAnalyticsSubscriptionId')), subscription().subscriptionId, parameters('logAnalyticsSubscriptionId'))]",
    "effectiveLogAnalyticsResourceGroup": "[if(empty(parameters('logAnalyticsResourceGroup')), resourceGroup().name, parameters('logAnalyticsResourceGroup'))]",
    "effectiveLogAnalyticsResourceId": "[if(empty(parameters('logAnalyticsResourceId')), resourceId(variables('effectiveLogAnalyticsSubscriptionId'), variables('effectiveLogAnalyticsResourceGroup'), 'Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName')), parameters('logAnalyticsResourceId'))]",
    "effectiveAppInsightsSubscriptionId": "[if(empty(parameters('applicationInsightsSubscriptionId')), subscription().subscriptionId, parameters('applicationInsightsSubscriptionId'))]",
    "effectiveAppInsightsResourceGroup": "[if(empty(parameters('applicationInsightsResourceGroup')), resourceGroup().name, parameters('applicationInsightsResourceGroup'))]",
    "effectiveAppInsightsResourceId": "[if(empty(parameters('applicationInsightsResourceId')), resourceId(variables('effectiveAppInsightsSubscriptionId'), variables('effectiveAppInsightsResourceGroup'), 'Microsoft.Insights/components', parameters('applicationInsightsName')), parameters('applicationInsightsResourceId'))]",
    "effectiveAppInsightsConnectionString": "[if(empty(parameters('applicationInsightsConnectionString')), reference(variables('effectiveAppInsightsResourceId'), '2020-02-02').ConnectionString, parameters('applicationInsightsConnectionString'))]",
    "effectiveDnsSubscriptionId": "[if(empty(parameters('dnsSubscriptionId')), subscription().subscriptionId, parameters('dnsSubscriptionId'))]",
    "effectiveDnsChallengeResourceGroup": "[if(empty(parameters('dnsChallengeResourceGroup')), parameters('dnsResourceGroup'), parameters('dnsChallengeResourceGroup'))]",
    "effectiveDnsZoneName": "[if(empty(parameters('dnsChallengeZoneName')), parameters('dnsZoneName'), parameters('dnsChallengeZoneName'))]",
    "effectiveDnsZoneResourceId": "[if(empty(parameters('dnsZoneResourceId')), resourceId(variables('effectiveDnsSubscriptionId'), variables('effectiveDnsChallengeResourceGroup'), 'Microsoft.Network/dnsZones', variables('effectiveDnsZoneName')), parameters('dnsZoneResourceId'))]",
    "keyVaultHost": "[first(split(replace(parameters('azureKeyVaultUrl'), 'https://', ''), '/'))]",
    "keyVaultName": "[first(split(variables('keyVaultHost'), '.'))]",
    "effectiveKeyVaultSubscriptionId": "[if(empty(parameters('keyVaultSubscriptionId')), subscription().subscriptionId, parameters('keyVaultSubscriptionId'))]",
    "effectiveKeyVaultResourceGroup": "[if(empty(parameters('keyVaultResourceGroup')), resourceGroup().name, parameters('keyVaultResourceGroup'))]",
    "effectiveKeyVaultResourceId": "[if(empty(parameters('keyVaultResourceId')), resourceId(variables('effectiveKeyVaultSubscriptionId'), variables('effectiveKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults', variables('keyVaultName')), parameters('keyVaultResourceId'))]"
  },
  "resources": [
    {
      "condition": "[and(equals(parameters('appInsightsMode'), 'new'), equals(parameters('logAnalyticsMode'), 'new'))]",
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[parameters('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "retentionInDays": 30,
        "features": {
          "searchVersion": 1
        },
        "sku": {
          "name": "PerGB2018"
        }
      }
    },
    {
      "condition": "[equals(parameters('appInsightsMode'), 'new')]",
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[parameters('applicationInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[if(equals(parameters('logAnalyticsMode'), 'new'), resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName')), variables('effectiveLogAnalyticsResourceId'))]"
      },
      "dependsOn": "[if(equals(parameters('logAnalyticsMode'), 'new'), createArray(resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName'))), createArray())]"
    },
    {
      "condition": "[equals(parameters('storageMode'), 'new')]",
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2024-01-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS",
        "tier": "Standard"
      },
      "kind": "StorageV2",
      "properties": {
        "accessTier": "Hot",
        "allowBlobPublicAccess": false,
        "allowSharedKeyAccess": false,
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "condition": "[equals(parameters('storageMode'), 'new')]",
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}', parameters('storageAccountName'), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ]
    },
    {
      "condition": "[variables('storageContainerManagedByTemplate')]",
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}/{2}', parameters('storageAccountName'), 'default', variables('effectiveDeploymentContainerName'))]",
      "properties": {
        "publicAccess": "None"
      },
      "dependsOn": "[if(equals(parameters('storageMode'), 'new'), createArray(resourceId('Microsoft.Storage/storageAccounts/blobServices', parameters('storageAccountName'), 'default')), createArray())]"
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[parameters('functionPlanName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "sku": {
        "tier": "FlexConsumption",
        "name": "FC1"
      },
      "properties": {
        "reserved": true,
        "zoneRedundant": "[parameters('zoneRedundant')]"
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('functionPlanName'))]",
        "httpsOnly": true,
        "functionAppConfig": {
          "deployment": {
            "storage": {
              "type": "blobContainer",
              "value": "[concat(reference(variables('effectiveStorageAccountResourceId')).primaryEndpoints.blob, variables('effectiveDeploymentContainerName'))]",
              "authentication": {
                "type": "SystemAssignedIdentity"
              }
            }
          },
          "scaleAndConcurrency": {
            "maximumInstanceCount": "[parameters('maximumInstanceCount')]",
            "instanceMemoryMB": "[parameters('instanceMemoryMB')]"
          },
          "runtime": {
            "name": "python",
            "version": "3.12"
          }
        },
        "siteConfig": {
          "appSettings": [
            {
              "name": "AzureWebJobsStorage__accountName",
              "value": "[parameters('storageAccountName')]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[variables('effectiveAppInsightsConnectionString')]"
            }
          ]
        }
      },
      "dependsOn": "[union(createArray(resourceId('Microsoft.Web/serverfarms', parameters('functionPlanName'))), if(variables('storageContainerManagedByTemplate'), createArray(resourceId('Microsoft.Storage/storageAccounts/blobServices/containers', parameters('storageAccountName'), 'default', variables('effectiveDeploymentContainerName'))), createArray()), if(equals(parameters('appInsightsMode'), 'new'), createArray(resourceId('Microsoft.Insights/components', parameters('applicationInsightsName'))), createArray()))]"
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(variables('effectiveStorageAccountResourceId'), variables('storageBlobDataOwnerRoleDefinitionId'))]",
      "scope": "[variables('effectiveStorageAccountResourceId')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('storageBlobDataOwnerRoleDefinitionId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
      ]
    },
    {
      "condition": "[parameters('dnsRoleAssignmentEnabled')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(variables('effectiveDnsZoneResourceId'), variables('dnsZoneContributorRoleDefinitionId'), parameters('functionAppName'))]",
      "scope": "[variables('effectiveDnsZoneResourceId')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('dnsZoneContributorRoleDefinitionId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
      ]
    },
    {
      "condition": "[parameters('keyVaultRoleAssignmentEnabled')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(variables('effectiveKeyVaultResourceId'), variables('keyVaultCertificatesOfficerRoleDefinitionId'), parameters('functionAppName'))]",
      "scope": "[variables('effectiveKeyVaultResourceId')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('keyVaultCertificatesOfficerRoleDefinitionId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
      ]
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[parameters('functionAppName')]"
    },
    "functionPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'Full').identity.principalId]"
    },
    "storageMode": {
      "type": "string",
      "value": "[parameters('storageMode')]"
    },
    "storageAccountScope": {
      "type": "string",
      "value": "[variables('effectiveStorageAccountResourceId')]"
    },
    "deploymentStorageContainer": {
      "type": "string",
      "value": "[variables('effectiveDeploymentContainerName')]"
    },
    "appInsightsMode": {
      "type": "string",
      "value": "[parameters('appInsightsMode')]"
    },
    "applicationInsightsScope": {
      "type": "string",
      "value": "[variables('effectiveAppInsightsResourceId')]"
    },
    "logAnalyticsMode": {
      "type": "string",
      "value": "[parameters('logAnalyticsMode')]"
    },
    "logAnalyticsScope": {
      "type": "string",
      "value": "[variables('effectiveLogAnalyticsResourceId')]"
    },
    "dnsRoleAssignmentScope": {
      "type": "string",
      "value": "[variables('effectiveDnsZoneResourceId')]"
    },
    "keyVaultRoleAssignmentScope": {
      "type": "string",
      "value": "[variables('effectiveKeyVaultResourceId')]"
    }
  }
}
