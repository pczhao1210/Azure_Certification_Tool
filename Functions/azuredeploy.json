{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "functionPlanName": {
      "type": "string"
    },
    "functionAppName": {
      "type": "string"
    },
    "functionAppRuntime": {
      "type": "string",
      "defaultValue": "python"
    },
    "functionAppRuntimeVersion": {
      "type": "string",
      "defaultValue": "3.12"
    },
    "storageAccountName": {
      "type": "string"
    },
    "logAnalyticsName": {
      "type": "string"
    },
    "applicationInsightsName": {
      "type": "string"
    },
    "acmeEmail": {
      "type": "string"
    },
    "acmeDomains": {
      "type": "string"
    },
    "acmeDirectoryUrl": {
      "type": "string",
      "defaultValue": "https://acme-v02.api.letsencrypt.org/directory"
    },
    "azureKeyVaultUrl": {
      "type": "string"
    },
    "azureCertificateName": {
      "type": "string"
    },
    "dnsSubscriptionId": {
      "type": "string",
      "defaultValue": ""
    },
    "dnsResourceGroup": {
      "type": "string"
    },
    "dnsZoneName": {
      "type": "string"
    },
    "dnsChallengeZoneName": {
      "type": "string",
      "defaultValue": ""
    },
    "dnsChallengeResourceGroup": {
      "type": "string",
      "defaultValue": ""
    },
    "renewalDaysBeforeExpiry": {
      "type": "int",
      "defaultValue": 30
    },
    "saveLocalCerts": {
      "type": "bool",
      "defaultValue": false
    },
    "certOutputDir": {
      "type": "string",
      "defaultValue": "/tmp/certificates"
    },
    "pfxPassword": {
      "type": "securestring",
      "defaultValue": ""
    },
    "acmeValidationTimeout": {
      "type": "int",
      "defaultValue": 900
    },
    "dnsPropagationTimeout": {
      "type": "int",
      "defaultValue": 900
    },
    "dnsPropagationInterval": {
      "type": "int",
      "defaultValue": 15
    },
    "dnsPropagationStableSeconds": {
      "type": "int",
      "defaultValue": 90
    },
    "publicDnsServers": {
      "type": "string",
      "defaultValue": "8.8.8.8,1.1.1.1,9.9.9.9,208.67.222.222"
    },
    "maximumInstanceCount": {
      "type": "int",
      "defaultValue": 40
    },
    "instanceMemoryMB": {
      "type": "int",
      "defaultValue": 2048,
      "allowedValues": [
        512,
        2048,
        4096
      ]
    },
    "zoneRedundant": {
      "type": "bool",
      "defaultValue": false
    },
    "dnsZoneResourceId": {
      "type": "string",
      "defaultValue": ""
    },
    "dnsRoleAssignmentEnabled": {
      "type": "bool",
      "defaultValue": true
    },
    "keyVaultSubscriptionId": {
      "type": "string",
      "defaultValue": ""
    },
    "keyVaultResourceGroup": {
      "type": "string",
      "defaultValue": ""
    },
    "keyVaultResourceId": {
      "type": "string",
      "defaultValue": ""
    },
    "keyVaultRoleAssignmentEnabled": {
      "type": "bool",
      "defaultValue": true
    }
  },
  "variables": {
    "resourceToken": "[toLower(uniqueString(subscription().id, resourceGroup().name, parameters('location'), parameters('functionAppName')))]",
    "deploymentStorageContainerName": "[concat('app-package-', take(parameters('functionAppName'), 16), '-', take(variables('resourceToken'), 7))]",
    "storageBlobDataOwnerRoleDefinitionId": "b7e6dc6d-f1e8-4753-8033-0f276bb0955b",
    "dnsZoneContributorRoleDefinitionId": "befefa01-2a29-4197-83a8-272ff33ce314",
    "keyVaultCertificatesOfficerRoleDefinitionId": "a4417e6f-fecd-4de8-b567-7b0420556985",
    "effectiveDnsSubscriptionId": "[if(empty(parameters('dnsSubscriptionId')), subscription().subscriptionId, parameters('dnsSubscriptionId'))]",
    "effectiveDnsChallengeResourceGroup": "[if(empty(parameters('dnsChallengeResourceGroup')), parameters('dnsResourceGroup'), parameters('dnsChallengeResourceGroup'))]",
    "effectiveDnsZoneName": "[if(empty(parameters('dnsChallengeZoneName')), parameters('dnsZoneName'), parameters('dnsChallengeZoneName'))]",
    "effectiveDnsZoneResourceId": "[if(empty(parameters('dnsZoneResourceId')), resourceId(variables('effectiveDnsSubscriptionId'), variables('effectiveDnsChallengeResourceGroup'), 'Microsoft.Network/dnsZones', variables('effectiveDnsZoneName')), parameters('dnsZoneResourceId'))]",
    "keyVaultHost": "[first(split(replace(parameters('azureKeyVaultUrl'), 'https://', ''), '/'))]",
    "keyVaultName": "[first(split(variables('keyVaultHost'), '.'))]",
    "effectiveKeyVaultSubscriptionId": "[if(empty(parameters('keyVaultSubscriptionId')), subscription().subscriptionId, parameters('keyVaultSubscriptionId'))]",
    "effectiveKeyVaultResourceGroup": "[if(empty(parameters('keyVaultResourceGroup')), resourceGroup().name, parameters('keyVaultResourceGroup'))]",
    "effectiveKeyVaultResourceId": "[if(empty(parameters('keyVaultResourceId')), resourceId(variables('effectiveKeyVaultSubscriptionId'), variables('effectiveKeyVaultResourceGroup'), 'Microsoft.KeyVault/vaults', variables('keyVaultName')), parameters('keyVaultResourceId'))]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[parameters('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "retentionInDays": 30,
        "features": {
          "searchVersion": 1
        },
        "sku": {
          "name": "PerGB2018"
        }
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[parameters('applicationInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2024-01-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS",
        "tier": "Standard"
      },
      "kind": "StorageV2",
      "properties": {
        "accessTier": "Hot",
        "allowBlobPublicAccess": false,
        "allowSharedKeyAccess": false,
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}', parameters('storageAccountName'), 'default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2024-01-01",
      "name": "[format('{0}/{1}/{2}', parameters('storageAccountName'), 'default', variables('deploymentStorageContainerName'))]",
      "properties": {
        "publicAccess": "None"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', parameters('storageAccountName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[parameters('functionPlanName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "sku": {
        "tier": "FlexConsumption",
        "name": "FC1"
      },
      "properties": {
        "reserved": true,
        "zoneRedundant": "[parameters('zoneRedundant')]"
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('functionPlanName'))]",
        "httpsOnly": true,
        "functionAppConfig": {
          "deployment": {
            "storage": {
              "type": "blobContainer",
              "value": "[concat(reference(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))).primaryEndpoints.blob, variables('deploymentStorageContainerName'))]",
              "authentication": {
                "type": "SystemAssignedIdentity"
              }
            }
          },
          "scaleAndConcurrency": {
            "maximumInstanceCount": "[parameters('maximumInstanceCount')]",
            "instanceMemoryMB": "[parameters('instanceMemoryMB')]"
          },
          "runtime": {
            "name": "[parameters('functionAppRuntime')]",
            "version": "[parameters('functionAppRuntimeVersion')]"
          }
        },
        "siteConfig": {
          "appSettings": [
            {
              "name": "AzureWebJobsStorage__accountName",
              "value": "[parameters('storageAccountName')]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', parameters('applicationInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "ACME_EMAIL",
              "value": "[parameters('acmeEmail')]"
            },
            {
              "name": "ACME_DOMAINS",
              "value": "[parameters('acmeDomains')]"
            },
            {
              "name": "ACME_DIRECTORY_URL",
              "value": "[parameters('acmeDirectoryUrl')]"
            },
            {
              "name": "AZURE_KEY_VAULT_URL",
              "value": "[parameters('azureKeyVaultUrl')]"
            },
            {
              "name": "AZURE_CERTIFICATE_NAME",
              "value": "[parameters('azureCertificateName')]"
            },
            {
              "name": "DNS_SUBSCRIPTION_ID",
              "value": "[variables('effectiveDnsSubscriptionId')]"
            },
            {
              "name": "DNS_RESOURCE_GROUP",
              "value": "[parameters('dnsResourceGroup')]"
            },
            {
              "name": "DNS_ZONE_NAME",
              "value": "[parameters('dnsZoneName')]"
            },
            {
              "name": "DNS_CHALLENGE_ZONE_NAME",
              "value": "[parameters('dnsChallengeZoneName')]"
            },
            {
              "name": "DNS_CHALLENGE_RESOURCE_GROUP",
              "value": "[variables('effectiveDnsChallengeResourceGroup')]"
            },
            {
              "name": "RENEWAL_DAYS_BEFORE_EXPIRY",
              "value": "[string(parameters('renewalDaysBeforeExpiry'))]"
            },
            {
              "name": "SAVE_LOCAL_CERTS",
              "value": "[string(parameters('saveLocalCerts'))]"
            },
            {
              "name": "CERT_OUTPUT_DIR",
              "value": "[parameters('certOutputDir')]"
            },
            {
              "name": "PFX_PASSWORD",
              "value": "[parameters('pfxPassword')]"
            },
            {
              "name": "ACME_VALIDATION_TIMEOUT",
              "value": "[string(parameters('acmeValidationTimeout'))]"
            },
            {
              "name": "DNS_PROPAGATION_TIMEOUT",
              "value": "[string(parameters('dnsPropagationTimeout'))]"
            },
            {
              "name": "DNS_PROPAGATION_INTERVAL",
              "value": "[string(parameters('dnsPropagationInterval'))]"
            },
            {
              "name": "DNS_PROPAGATION_STABLE_SECONDS",
              "value": "[string(parameters('dnsPropagationStableSeconds'))]"
            },
            {
              "name": "PUBLIC_DNS_SERVERS",
              "value": "[parameters('publicDnsServers')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('functionPlanName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices/containers', parameters('storageAccountName'), 'default', variables('deploymentStorageContainerName'))]",
        "[resourceId('Microsoft.Insights/components', parameters('applicationInsightsName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), variables('storageBlobDataOwnerRoleDefinitionId'))]",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('storageBlobDataOwnerRoleDefinitionId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
        "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
      ]
    },
    {
      "condition": "[parameters('dnsRoleAssignmentEnabled')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(variables('effectiveDnsZoneResourceId'), variables('dnsZoneContributorRoleDefinitionId'), parameters('functionAppName'))]",
      "scope": "[variables('effectiveDnsZoneResourceId')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('dnsZoneContributorRoleDefinitionId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
      ]
    },
    {
      "condition": "[parameters('keyVaultRoleAssignmentEnabled')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(variables('effectiveKeyVaultResourceId'), variables('keyVaultCertificatesOfficerRoleDefinitionId'), parameters('functionAppName'))]",
      "scope": "[variables('effectiveKeyVaultResourceId')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('keyVaultCertificatesOfficerRoleDefinitionId'))]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"
      ]
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[parameters('functionAppName')]"
    },
    "functionPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01', 'Full').identity.principalId]"
    },
    "deploymentStorageContainer": {
      "type": "string",
      "value": "[variables('deploymentStorageContainerName')]"
    },
    "dnsRoleAssignmentScope": {
      "type": "string",
      "value": "[variables('effectiveDnsZoneResourceId')]"
    },
    "keyVaultRoleAssignmentScope": {
      "type": "string",
      "value": "[variables('effectiveKeyVaultResourceId')]"
    }
  }
}